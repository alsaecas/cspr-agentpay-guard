# =============================================================================
# CSPR AgentPay Guard — Paid API Environment
# =============================================================================
# Copy this file to .env and fill in values for your local setup.
# Never commit .env or secret key files.

# App mode: mock | casper-testnet
AGENTPAY_MODE=mock
AGENTPAY_DEMO_SEED=agentpay-demo

# Demo identity
AGENT_ID=agent_research_001
MERCHANT_ID=merchant_market_data_001
MERCHANT_ACCOUNT=mock-merchant-account
POLICY_ID=policy_demo_agent_001

# Server
PORT=4000

# Casper network (only needed for real Casper Testnet mode)
CASPER_NETWORK=casper-test
CASPER_RPC_URL=https://node.testnet.cspr.cloud/rpc
