# App mode (mock only for now)
NEXT_PUBLIC_AGENTPAY_MODE=mock

# Paid API base URL (must be running externally)
AGENTPAY_PAID_API_BASE_URL=http://127.0.0.1:4000

# Demo identity
AGENTPAY_DEFAULT_POLICY_ID=policy_demo_agent_001
AGENTPAY_DEFAULT_AGENT_ID=agent_research_001

# Target resource for demo flow
AGENTPAY_TARGET_URL=http://127.0.0.1:4000/premium/parking-report/MAD-001

# Auto-settle after successful retrieval
AGENTPAY_AUTO_SETTLE=true
