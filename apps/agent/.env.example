# =============================================================================
# CSPR AgentPay Guard — Agent Demo Environment
# =============================================================================

# App mode (mock only for now)
AGENTPAY_AGENT_MODE=mock

# Paid API base URL (used when auto-start is disabled)
AGENTPAY_PAID_API_BASE_URL=http://127.0.0.1:4000

# Demo identity
AGENTPAY_AGENT_ID=agent_research_001
AGENTPAY_POLICY_ID=policy_demo_agent_001

# Target resource URL
AGENTPAY_TARGET_URL=http://127.0.0.1:4000/premium/parking-report/MAD-001

# Start paid-api in-process (self-contained demo)
AGENTPAY_AUTO_START_PAID_API=true

# Auto-settle after successful resource retrieval
AGENTPAY_AUTO_SETTLE=true

# Port for in-process paid-api server
AGENTPAY_DEMO_PORT=4000
