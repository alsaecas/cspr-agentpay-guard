# =============================================================================
# CSPR AgentPay Guard — MCP Server Environment
# =============================================================================
# Copy this file to .env and fill in values for your local setup.

# MCP transport: stdio | streamable-http
AGENTPAY_MCP_TRANSPORT=stdio

# Paid API base URL (must be running)
AGENTPAY_PAID_API_BASE_URL=http://127.0.0.1:4000

# Default identity for tool calls
AGENTPAY_DEFAULT_POLICY_ID=policy_demo_agent_001
AGENTPAY_DEFAULT_AGENT_ID=agent_research_001

# Auto-setup demo state before tool calls
AGENTPAY_AUTO_SETUP=true

# Auto-settle payments after successful resource retrieval
AGENTPAY_AUTO_SETTLE=false
