# =============================================================================
# CSPR AgentPay Guard — Casper Adapter Environment
# =============================================================================
# Copy this file to .env and fill in values for your local setup.
# Never commit .env or secret key files.

# App mode: mock | casper-testnet
AGENTPAY_MODE=mock
AGENTPAY_DEMO_SEED=agentpay-demo

# Casper network target
CASPER_NETWORK=casper-test
CASPER_RPC_URL=https://node.testnet.cspr.cloud/rpc
CASPER_NODE_SSE_URL=

# CSPR.cloud (indexing, streaming, event reads)
CSPR_CLOUD_AUTH_TOKEN=
CSPR_CLOUD_API_URL=
CSPR_CLOUD_STREAM_URL=

# Casper AgentPay contract hashes (populated after deployment)
CASPER_AGENTPAY_CONTRACT_PACKAGE_HASH=
CASPER_AGENTPAY_CONTRACT_HASH=
POLICY_REGISTRY_HASH=
MERCHANT_REGISTRY_HASH=
PAYMENT_ESCROW_HASH=

# Testnet account keys (required for real Casper Testnet mode)
CASPER_TESTNET_PUBLIC_KEY=
CASPER_TESTNET_SECRET_KEY_PATH=
CASPER_MERCHANT_PUBLIC_KEY=
CASPER_MERCHANT_ACCOUNT_HASH=

# Gas configuration
CASPER_PAYMENT_GAS_MOTES=100000000
